#: data/org.gnome.Weather.desktop.in.in:13
msgid "Allows weather information to be displayed for your location."
msgstr "Syner vêrdata for staden din."

#: data/org.gnome.Weather.gschema.xml:6
msgid "Configured cities to show weather for"
msgstr "Valde byar som det skal visast vêr for"

#: data/org.gnome.Weather.gschema.xml:7
msgid ""
"The locations shown in the world view of gnome-weather. Each value is a GVariant "
"returned by gweather_location_serialize()."
msgstr ""
"Stadene som blir viste i verdsvisinga av GNOME Vêr. Kvar verdi er ein GVariant frå "
"gweather_location_serialize()."

